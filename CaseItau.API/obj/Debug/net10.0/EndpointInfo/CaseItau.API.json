{
  "openapi": "3.1.1",
  "info": {
    "title": "CaseItau.API | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:5001"
    },
    {
      "url": "http://localhost:5000"
    }
  ],
  "paths": {
    "/api/Fundo": {
      "get": {
        "tags": [
          "Fundo"
        ],
        "summary": "Listar todos os fundos",
        "description": "Retorna todos os fundos cadastrados com tipo específico e patrimônio.\r\n\r\nExemplo de retorno:\r\n\r\n    [\r\n      {\r\n        \"code\": \"ITAUTESTE01\",\r\n        \"name\": \"Fundo Teste\",\r\n        \"document\": \"12345678000190\",\r\n        \"grossValue\": 1500000.00,\r\n        \"fundType\": {\r\n          \"id\": 1,\r\n          \"name\": \"RENDA_FIXA\"\r\n        }\r\n      }\r\n    ]",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FundResult"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FundResult"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FundResult"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Fundo"
        ],
        "summary": "Criar um novo fundo",
        "description": "Cria um novo fundo de investimento.\r\n\r\nTipos de fundo disponíveis:\r\n\r\n    1 - RENDA FIXA\r\n    2 - ACOES\r\n    3 - MULTI MERCADO\r\n\r\nExemplo de requisição:\r\n\r\n    POST /api/Fundo\r\n    {\r\n      \"code\": \"ITAUTESTE01\",\r\n      \"name\": \"Fundo Teste\",\r\n      \"document\": \"12345678000190\",\r\n      \"fundType\": 1,\r\n      \"grossValue\": 1500000.00\r\n    }",
        "requestBody": {
          "description": "Dados do fundo a ser criado",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFundCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFundCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFundCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Fundo criado com sucesso"
          },
          "400": {
            "description": "Dados inválidos ou fundo já existente",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno no servidor"
          }
        }
      }
    },
    "/api/Fundo/{code}": {
      "get": {
        "tags": [
          "Fundo"
        ],
        "summary": "Buscar fundo pelo código",
        "description": "Retorna um fundo específico a partir do seu código.\r\n\r\nExemplo de retorno:\r\n\r\n    {\r\n      \"code\": \"ITAUTESTE01\",\r\n      \"name\": \"Fundo Teste\",\r\n      \"document\": \"12345678000190\",\r\n      \"grossValue\": 1500000.00,\r\n      \"fundType\": {\r\n        \"id\": 1,\r\n        \"name\": \"RENDA_FIXA\"\r\n      }\r\n    }\r\n\r\nExemplo de requisição:\r\n\r\n    GET /api/Fundo/ITAUTESTE01",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "description": "Código do fundo a ser consultado",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Retorna o fundo encontrado",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/FundResult"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FundResult"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/FundResult"
                }
              }
            }
          },
          "404": {
            "description": "Fundo não encontrado",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno no servidor"
          }
        }
      },
      "put": {
        "tags": [
          "Fundo"
        ],
        "summary": "Atualizar um fundo existente",
        "description": "Atualiza os dados de um fundo existente.\r\n\r\nTipos de fundo disponíveis:\r\n\r\n    1 - RENDA FIXA\r\n    2 - ACOES\r\n    3 - MULTI MERCADO\r\n\r\nExemplo de requisição:\r\n\r\n    PUT /api/Fundo/ITAUTESTE01\r\n    {\r\n      \"code\": \"ITAUTESTE01\",\r\n      \"name\": \"Novo Nome\",\r\n      \"document\": \"12345678000190\",\r\n      \"fundType\": 2\r\n    }",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "description": "Código do fundo a ser atualizado",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Dados atualizados do fundo",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateFundCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateFundCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateFundCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Fundo atualizado com sucesso",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/FundResult"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FundResult"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/FundResult"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Fundo não encontrado",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "409": {
            "description": "Já existe um fundo com o código ou CNPJ informado",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno no servidor"
          }
        }
      },
      "delete": {
        "tags": [
          "Fundo"
        ],
        "summary": "Remover um fundo existente",
        "description": "Remove permanentemente um fundo de investimento a partir do seu código.\r\n\r\nExemplo de requisição:\r\n\r\n    DELETE /api/Fundo/ITAUTESTE01",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "description": "Código do fundo a ser removido",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Fundo removido com sucesso"
          },
          "404": {
            "description": "Fundo não encontrado",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno no servidor"
          }
        }
      }
    },
    "/api/Fundo/{code}/patrimonio": {
      "put": {
        "tags": [
          "Fundo"
        ],
        "summary": "Atualizar o patrimônio de um fundo",
        "description": "Adiciona ou subtrai um valor do patrimônio bruto de um fundo existente.\r\n\r\nO valor informado é somado ao patrimônio atual. Use valores negativos para subtrair.\r\n\r\nExemplos de requisição:\r\n\r\n    PUT /api/Fundo/ITAUTESTE01/patrimonio\r\n    { \"grossValue\": 500.00 }   → adiciona 500 ao patrimônio atual\r\n\r\n    PUT /api/Fundo/ITAUTESTE01/patrimonio\r\n    { \"grossValue\": -200.00 }  → subtrai 200 do patrimônio atual",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "description": "Código do fundo a ser atualizado",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Valor a adicionar (positivo) ou subtrair (negativo) do patrimônio",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateFundGrossValueCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateFundGrossValueCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateFundGrossValueCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Patrimônio atualizado com sucesso",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/FundResult"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FundResult"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/FundResult"
                }
              }
            }
          },
          "400": {
            "description": "Valor de patrimônio inválido",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Fundo não encontrado",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno no servidor"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateFundCommand": {
        "type": "object",
        "properties": {
          "code": {
            "type": [
              "null",
              "string"
            ]
          },
          "name": {
            "type": [
              "null",
              "string"
            ]
          },
          "document": {
            "type": [
              "null",
              "string"
            ]
          },
          "fundType": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "grossValue": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "FundResult": {
        "required": [
          "code",
          "name",
          "document",
          "grossValue",
          "fundType"
        ],
        "type": "object",
        "properties": {
          "code": {
            "type": [
              "null",
              "string"
            ]
          },
          "name": {
            "type": [
              "null",
              "string"
            ]
          },
          "document": {
            "type": [
              "null",
              "string"
            ]
          },
          "grossValue": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "fundType": {
            "$ref": "#/components/schemas/FundTypeResult"
          }
        }
      },
      "FundTypeResult": {
        "required": [
          "id",
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "name": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "UpdateFundCommand": {
        "type": "object",
        "properties": {
          "code": {
            "type": [
              "null",
              "string"
            ]
          },
          "name": {
            "type": [
              "null",
              "string"
            ]
          },
          "document": {
            "type": [
              "null",
              "string"
            ]
          },
          "fundType": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "UpdateFundGrossValueCommand": {
        "type": "object",
        "properties": {
          "code": {
            "type": [
              "null",
              "string"
            ]
          },
          "grossValue": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Fundo"
    }
  ]
}